datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  balance       Int      @default(100000) // balance stored in cents (e.g. 100000 = $1,000.00 starting bonus)
  bank          Int      @default(0)      // "cashed out" chips stored here; players buy chips from bank to play
  level         Int      @default(1)
  xp            Int      @default(0)
  createdAt     DateTime @default(now())

  // Provably-fair seed pair currently active for this user
  clientSeed    String   @default("default-client-seed")
  serverSeed    String
  serverSeedHash String
  nonce         Int      @default(0)

  isBanned      Boolean  @default(false)
  nickname      String?
  rank          String   @default("bronze")
  emailVerified    Boolean  @default(false)
  emailToken       String?
  emailTokenExpiry DateTime?

  bets              Bet[]
  transactions      Transaction[]
  seedHistory       SeedRotation[]
  rakeback          RakebackClaim[]
  sentRequests      FriendRequest[] @relation("SentRequests")
  receivedRequests  FriendRequest[] @relation("ReceivedRequests")
  friendships       Friendship[]    @relation("UserFriends")
  friendOf          Friendship[]    @relation("FriendOf")
  nfts              Nft[]
  sentTrades        TradeOffer[]    @relation("SentTrades")
  receivedTrades    TradeOffer[]    @relation("ReceivedTrades")

  @@index([balance])
  @@index([level])
}

model SeedRotation {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  serverSeed      String   // revealed (previous) server seed
  serverSeedHash  String
  clientSeed      String
  nonceCount      Int
  rotatedAt       DateTime @default(now())

  @@index([userId])
}

model Bet {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  game        String   // dice | crash | mines | limbo | roulette | blackjack | plinko | slots
  amount      Int      // wager, in cents
  payout      Int      // amount returned to user, in cents (0 = total loss)
  multiplier  Float    // resulting multiplier (payout / amount), 0 if lost
  state       String   // JSON blob describing the round (per-game shape)
  result      String   // "win" | "loss"
  clientSeed  String
  serverSeed  String   // revealed seed used for this bet (hashed seed was shown beforehand)
  nonce       Int
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([game])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // deposit | withdrawal | bet | payout | rakeback | bonus | levelup_bonus
  amount    Int      // signed delta, in cents
  balance   Int      // resulting balance after applying this transaction
  reference String?  // related bet id, claim id, etc.
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model RakebackClaim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model FriendRequest {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  status    String   @default("pending") // pending | accepted | rejected
  createdAt DateTime @default(now())
  from      User     @relation("SentRequests", fields: [fromId], references: [id])
  to        User     @relation("ReceivedRequests", fields: [toId], references: [id])

  @@unique([fromId, toId])
  @@index([toId])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  user      User     @relation("UserFriends", fields: [userId], references: [id])
  friend    User     @relation("FriendOf", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([userId])
}

model CrashRound {
  id           String   @id @default(cuid())
  roundNumber  Int      @unique
  serverSeed   String
  serverSeedHash String
  crashPoint   Float
  state        String   // betting | running | crashed
  startedAt    DateTime @default(now())
  endedAt      DateTime?
}

model HouseBank {
  id        String   @id
  chips     Int      @default(1000000000)
  dollars   Int      @default(1000000000)
  updatedAt DateTime @updatedAt
}

model HouseBankTransaction {
  id            String   @id @default(cuid())
  type          String
  chipsChange   Int      @default(0)
  dollarsChange Int      @default(0)
  note          String?
  createdAt     DateTime @default(now())
}

model Nft {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  name        String
  description String
  rarity      String   // common | uncommon | rare | epic | legendary
  category    String   // win | level | first | streak | special
  emoji       String
  mintedAt    DateTime @default(now())
  tradeItems  TradeOfferItem[]

  @@index([ownerId])
}

model TradeOffer {
  id              String   @id @default(cuid())
  fromId          String
  toId            String
  offeredChips    Int      @default(0)
  requestedChips  Int      @default(0)
  status          String   @default("pending") // pending | accepted | declined | cancelled
  message         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  from            User     @relation("SentTrades", fields: [fromId], references: [id])
  to              User     @relation("ReceivedTrades", fields: [toId], references: [id])
  items           TradeOfferItem[]

  @@index([fromId])
  @@index([toId, status])
}

model TradeOfferItem {
  id           String     @id @default(cuid())
  tradeOfferId String
  nftId        String
  side         String     // offered | requested
  tradeOffer   TradeOffer @relation(fields: [tradeOfferId], references: [id])
  nft          Nft        @relation(fields: [nftId], references: [id])
}

model JackpotRound {
  id          String   @id @default(cuid())
  status      String   @default("open")  // open | spinning | closed
  totalPot    Int      @default(0)
  winnerId    String?
  winnerName  String?
  entries     String   @default("[]") // JSON array of { userId, username, amount }
  createdAt   DateTime @default(now())
  closedAt    DateTime?
}
