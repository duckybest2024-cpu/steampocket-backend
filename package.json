{
  "name": "casino-aurelius",
  "version": "1.0.0",
  "description": "Provably-fair casino backend — dice, crash, mines, limbo, roulette, blackjack, plinko, slots",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "vercel-build": "prisma generate && tsc -p tsconfig.json",
    "start": "prisma db push --skip-generate --accept-data-loss && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.11",
    "socket.io": "^4.8.1",
    "stripe": "^22.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
